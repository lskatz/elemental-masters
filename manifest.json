---
# Front matter forces Jekyll to process this file with Liquid so we can
# resolve relative_url. Final filename is /manifest.json after Jekyll build.
permalink: /manifest.json
---
{
  "name": "Elemental Masters",
  "short_name": "Elemental",
  "description": "A never-ending elemental battling game.",
  "start_url": "{{ '/' | relative_url }}",
  "scope": "{{ '/' | relative_url }}",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0e0822",
  "theme_color": "#1a1033",
  "lang": "en",
  "icons": [
    {
      "src": "{{ '/assets/icons/icon-192.png' | relative_url }}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "{{ '/assets/icons/icon-512.png' | relative_url }}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
